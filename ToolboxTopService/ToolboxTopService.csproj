<Project Sdk="Microsoft.NET.Sdk">

	<!-- project definition -->
	<PropertyGroup>
		<TargetFramework>$(DefaultNetVersion)-windows</TargetFramework>
		<RootNamespace>aemarcoCommons.ToolboxTopService</RootNamespace>
		<AssemblyName>aemarcoCommons.ToolboxTopService</AssemblyName>
	</PropertyGroup>

	<!-- project references -->
	<ItemGroup>
		<ProjectReference Include="..\Extensions\Extensions.csproj" />
	</ItemGroup>

	<!-- nuget references -->
	<ItemGroup>
		<PackageReference Include="CliWrap" />
		<PackageReference Include="Microsoft.Extensions.Hosting.WindowsServices" />
	</ItemGroup>

	<!-- nuget build-->
	<PropertyGroup>
		<Description>Tool for installing a Windows service</Description>
		<PackageTags>WindowsService Topshelf</PackageTags>
	</PropertyGroup>
	<ItemGroup>
		<None Include="README.md" Pack="true" PackagePath="\" />
		<None Include="Resources\icon.png" Pack="true" PackagePath="\" />
		<None Include="Resources\LICENSE.md" Pack="true" PackagePath="\" />
		<None Include="Resources\NOTICE.md" Pack="true" PackagePath="\" />
	</ItemGroup>
	
</Project>
